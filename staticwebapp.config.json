{
  "routes": [
    {
      "route": "/api/grind",
      "allowedRoles": ["authenticated"],
      "headers": {
        "Cache-Control": "no-store",
        "X-Robots-Tag": "noindex, nofollow"
      }
    },
    {
      "route": "/grind*",
      "headers": {
        "Cache-Control": "no-store",
        "X-Robots-Tag": "noindex, nofollow"
      }
    },
    {
      "route": "/articles/wip-*",
      "allowedRoles": ["owner"],
      "headers": {
        "Cache-Control": "no-store",
        "X-Robots-Tag": "noindex, nofollow"
      }
    },
    {
      "route": "/login",
      "redirect": "/.auth/login/github"
    },
    {
      "route": "/logout",
      "redirect": "/.auth/logout"
    }
  ],
  "responseOverrides": {
    "401": {
      "statusCode": 302,
      "redirect": "/.auth/login/github?post_login_redirect_uri=.referrer"
    },
    "403": {
      "rewrite": "/private.html"
    }
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "strict-origin-when-cross-origin",
    "X-Frame-Options": "DENY"
  },
  "forwardingGateway": {
    "allowedForwardedHosts": [
      "danielchu.dev",
      "www.danielchu.dev",
      "personalweb-apex-dchu83-hpcbd7f3fjg4cddt.z01.azurefd.net"
    ]
  },
  "platform": {
    "apiRuntime": "node:20"
  },
  "mimeTypes": {
    ".ico": "image/x-icon",
    ".svg": "image/svg+xml"
  }
}
